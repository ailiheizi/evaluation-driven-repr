  },
  {
   "start": 363.16,
   "end": 363.48,
   "text": "差不多"
  },
  {
   "start": 363.48,
   "end": 364.2,
   "text": "难道说"
  },
  {
   "start": 364.2,
   "end": 365.48,
   "text": "怎么啦 小朋友"
  },
  {
   "start": 365.48,
   "end": 367.0,
   "text": "胜利就在眼前"
  },
  {
   "start": 367.0,
   "end": 368.68,
   "text": "你将会是拯救了同学的英雄"
  },
  {
   "start": 368.72,
   "end": 369.52,
   "text": "可你"
  },
  {
   "start": 369.52,
   "end": 370.4,
   "text": "不就成了被所有人"
  },
  {
   "start": 370.4,
