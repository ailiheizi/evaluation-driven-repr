{
 "segments": [
  {
   "start": 0.0,
   "end": 3.44,
   "text": "7是IGN在他面試之前給出的分數"
  },
  {
   "start": 3.44,
   "end": 7.32,
   "text": "1.5086億是他在全球範圍內至今的銷量"
  },
  {
   "start": 7.32,
   "end": 9.36,
   "text": "僅次於PS2和NDS"
  },
  {
   "start": 9.36,
   "end": 10.68,
   "text": "在這張榜單上"
  },
  {
   "start": 10.68,
   "end": 12.96,
   "text": "他也是唯一一台無法被劃分鏡"
  },
  {
   "start": 12.96,
   "end": 16.72,
   "text": "家用機或是長機的hybrid混血主機"
  },
  {
   "start": 16.72,
   "end": 18.72,
   "text": "如今他8歲了"
  },
  {
   "start": 18.72,
   "end": 20.74,
   "text": "即將成為歷史"
  },
  {
   "start": 20.74,
   "end": 22.74,
   "text": "他就是"
  },
  {
   "start": 22.74,
   "end": 25.56,
   "text": "任天堂Switch"
  },
  {
   "start": 25.56,
   "end": 27.4,
   "text": "不被看好到銷量神話"
  },
  {
   "start": 27.4,
   "end": 29.08,
   "text": "Switch是如何做到的"
  },
  {
   "start": 29.08,
   "end": 30.64,
   "text": "2017到2025"
  },
  {
   "start": 30.64,
   "end": 33.6,
   "text": "今天我們一起重走這8年"
  },
  {
   "start": 33.6,
   "end": 50.7,
   "text": "7年1月13日"
  },
  {
   "start": 50.7,
   "end": 52.66,
   "text": "任天堂在東京召開發佈會"
  },
  {
   "start": 52.66,
   "end": 54.26,
   "text": "時事社長君道達吉"
  },
  {
   "start": 54.26,
   "end": 56.94,
   "text": "正式介紹了這台全新的混合主機"
  },
  {
   "start": 56.94,
   "end": 59.18,
   "text": "他既是一台功能完整的家用機"
  },
  {
   "start": 59.18,
   "end": 61.5,
   "text": "又可以隨時拿起變成長機"
  },
  {
   "start": 61.5,
   "end": 63.14,
   "text": "還可以拆下兩側的小手柄"
  },
  {
   "start": 63.14,
   "end": 64.82,
   "text": "與身邊的朋友共同遊戲"
  },
  {
   "start": 64.82,
   "end": 66.34,
   "text": "這種形態的混血主機"
  },
  {
   "start": 66.34,
   "end": 67.9,
   "text": "可以說是前所未見"
  },
  {
   "start": 67.9,
   "end": 69.14,
   "text": "宣傳片一出"
  },
  {
   "start": 69.14,
   "end": 70.42,
   "text": "掌聲歡呼"
  },
  {
   "start": 70.42,
   "end": 71.98,
   "text": "全球玩家都沸騰了"
  },
  {
   "start": 71.98,
   "end": 74.06,
   "text": "Switch就此橫空出世"
  },
  {
   "start": 74.06,
   "end": 76.18,
   "text": "一切看起來都是如此順利"
  },
  {
   "start": 76.18,
   "end": 78.5,
   "text": "但這個故事裡有兩個詞"
  },
  {
   "start": 78.5,
   "end": 79.98,
   "text": "其實是不準確的"
  },
  {
   "start": 79.98,
   "end": 82.74,
   "text": "Switch的混合概念並非前所未見"
  },
  {
   "start": 82.74,
   "end": 85.46,
   "text": "他的誕生也並非如此順利"
  },
  {
   "start": 85.46,
   "end": 88.58,
   "text": "Switch在發佈之前的名字叫做NX"
  },
  {
   "start": 88.58,
   "end": 89.82,
   "text": "是實驗社長顏天松"
  },
  {
   "start": 89.82,
   "end": 91.86,
   "text": "在2015年3月透露的"
  },
  {
   "start": 91.86,
   "end": 93.02,
   "text": "在過後的一年半裡"
  },
  {
   "start": 93.02,
   "end": 94.7,
   "text": "NX主機爆料不斷"
  },
  {
   "start": 94.7,
   "end": 95.9,
   "text": "包括所用芯片"
  },
  {
   "start": 95.9,
   "end": 96.86,
   "text": "第三方遊戲支持"
  },
  {
   "start": 96.86,
   "end": 98.42,
   "text": "以及混合主機的概念"
  },
  {
   "start": 98.42,
   "end": 100.7,
   "text": "然而到了2016年10月"
  },
  {
   "start": 100.7,
   "end": 102.14,
   "text": "當任天堂真的官宣"
  },
  {
   "start": 102.14,
   "end": 104.5,
   "text": "新主機命名為Nintendo Switch"
  },
  {
   "start": 104.5,
   "end": 106.7,
   "text": "並證實之前關於NX的猜想"
  },
  {
   "start": 106.7,
   "end": 108.06,
   "text": "都是正確的時候"
  },
  {
   "start": 108.06,
   "end": 111.06,
   "text": "任天堂的股價卻在次日下跌了"
  },
  {
   "start": 111.06,
   "end": 112.98,
   "text": "投資者們並不相信這個混血兒"
  },
  {
   "start": 112.98,
   "end": 114.1,
   "text": "能成什麼大企"
  },
  {
   "start": 114.1,
   "end": 115.58,
   "text": "甚至直到2017年"
  },
  {
   "start": 115.58,
   "end": 117.86,
   "text": "IGN在拿到實機試完之後"
  },
  {
   "start": 117.86,
   "end": 119.22,
   "text": "也打出了7分"
  },
  {
   "start": 119.22,
   "end": 121.22,
   "text": "這樣一個令人失望的評分"
  },
  {
   "start": 121.22,
   "end": 122.06,
   "text": "但 bottom line"
  },
  {
   "start": 122.06,
   "end": 122.78,
   "text": "是Switch"
  },
  {
   "start": 122.78,
   "end": 124.66,
   "text": "不做任何一件事"
  },
  {
   "start": 124.66,
   "end": 125.34,
   "text": "可以做的"
  },
  {
   "start": 125.34,
   "end": 126.38,
   "text": "無論如何"
  },
  {
   "start": 126.38,
   "end": 128.1,
   "text": "有什麼意義的解釋"
  },
  {
   "start": 128.1,
   "end": 130.18,
   "text": "為什麼NX還什麼都沒有做"
  },
  {
   "start": 130.18,
   "end": 131.58,
   "text": "就被看摔了呢"
  },
  {
   "start": 131.58,
   "end": 133.38,
   "text": "罪魁禍首就是他"
  },
  {
   "start": 133.42,
   "end": 134.14,
   "text": "VU"
  },
  {
   "start": 134.14,
   "end": 136.06,
   "text": "VU是Switch的上人機型"
  },
  {
   "start": 136.06,
   "end": 139.18,
   "text": "也是賣了1億台之多的V的機人機型"
  },
  {
   "start": 139.18,
   "end": 140.94,
   "text": "同樣還是任天堂史上"
  },
  {
   "start": 140.94,
   "end": 143.54,
   "text": "銷量最差的家用主機"
  },
  {
   "start": 143.54,
   "end": 144.86,
   "text": "預期銷量1億台"
  },
  {
   "start": 144.86,
   "end": 147.34,
   "text": "實際銷量1356萬台"
  },
  {
   "start": 147.34,
   "end": 148.82,
   "text": "顏田聰甚至不得不為這樣"
  },
  {
   "start": 148.82,
   "end": 150.06,
   "text": "慘淡的市場表現"
  },
  {
   "start": 150.06,
   "end": 152.3,
   "text": "多次向玩家傳達歉意"
  },
  {
   "start": 152.3,
   "end": 153.66,
   "text": "前任死的慘烈"
  },
  {
   "start": 153.66,
   "end": 155.7,
   "text": "當然是不被看好的原因之一"
  },
  {
   "start": 155.7,
   "end": 157.98,
   "text": "但更重要的是Switch"
  },
  {
   "start": 157.98,
   "end": 160.58,
   "text": "其實和VU還挺像"
  },
  {
   "start": 160.58,
   "end": 162.94,
   "text": "這是VU的主機本體"
  },
  {
   "start": 162.94,
   "end": 165.3,
   "text": "而這個是VU GamePad"
  },
  {
   "start": 165.3,
   "end": 166.58,
   "text": "也就是手柄"
  },
  {
   "start": 166.58,
   "end": 168.58,
   "text": "但卻帶了一塊6.2英寸"
  },
  {
   "start": 168.58,
   "end": 170.54,
   "text": "480P的電組觸摸屏"
  },
  {
   "start": 170.54,
   "end": 173.06,
   "text": "可以配合遊戲顯示不同的可互動內容"
  },
  {
   "start": 173.06,
   "end": 174.3,
   "text": "還可以在關閉電視後"
  },
  {
   "start": 174.3,
   "end": 175.46,
   "text": "用off TV模式"
  },
  {
   "start": 175.46,
   "end": 176.34,
   "text": "單獨外遊戲"
  },
  {
   "start": 176.34,
   "end": 177.78,
   "text": "相機了一台掌機"
  },
  {
   "start": 177.78,
   "end": 179.18,
   "text": "它裡面甚拆裝了"
  },
  {
   "start": 179.18,
   "end": 179.9,
   "text": "加速器"
  },
  {
   "start": 179.9,
   "end": 180.46,
   "text": "陀螺椅"
  },
  {
   "start": 180.46,
   "end": 181.22,
   "text": "前置攝像頭"
  },
  {
   "start": 181.22,
   "end": 181.78,
   "text": "麥克風"
  },
  {
   "start": 181.78,
   "end": 182.38,
   "text": "揚聲器"
  },
  {
   "start": 182.38,
   "end": 183.38,
   "text": "以及NFC模塊"
  },
  {
   "start": 183.38,
   "end": 184.62,
   "text": "這不就是電視"
  },
  {
   "start": 184.62,
   "end": 185.22,
   "text": "加掌機"
  },
  {
   "start": 185.22,
   "end": 186.66,
   "text": "互相切換的概念嗎"
  },
  {
   "start": 186.66,
   "end": 187.42,
   "text": "整理好啊"
  },
  {
   "start": 187.42,
   "end": 188.74,
   "text": "怎麼就失敗了呢"
  },
  {
   "start": 188.74,
   "end": 189.5,
   "text": "主要原因"
  },
  {
   "start": 189.5,
   "end": 190.22,
   "text": "有兩個"
  },
  {
   "start": 190.22,
   "end": 192.78,
   "text": "一個是缺乏第三方遊戲軟件的支持"
  },
  {
   "start": 192.78,
   "end": 194.82,
   "text": "導致能玩的遊戲不夠多"
  },
  {
   "start": 194.82,
   "end": 196.98,
   "text": "另一個就是這個倒霉名字"
  },
  {
   "start": 196.98,
   "end": 197.82,
   "text": "VU"
  },
  {
   "start": 197.82,
   "end": 199.9,
   "text": "聽起來就像是無語的配件"
  },
  {
   "start": 199.9,
   "end": 201.14,
   "text": "GamePad又是啥"
  },
  {
   "start": 201.14,
   "end": 202.18,
   "text": "是配件吧"
  },
  {
   "start": 202.18,
   "end": 202.62,
   "text": "哎"
  },
  {
   "start": 202.62,
   "end": 203.42,
   "text": "不買不買"
  },
  {
   "start": 203.42,
   "end": 206.34,
   "text": "對於這個沒有任何宣傳效果的名字"
  },
  {
   "start": 206.34,
   "end": 208.66,
   "text": "任天堂也是十分後悔"
  },
  {
   "start": 208.66,
   "end": 210.34,
   "text": "他找了大師算命"
  },
  {
   "start": 210.34,
   "end": 211.74,
   "text": "大師說"
  },
  {
   "start": 211.74,
   "end": 212.74,
   "text": "V"
  },
  {
   "start": 212.74,
   "end": 213.58,
   "text": "諧音"
  },
  {
   "start": 213.58,
   "end": 216.56,
   "text": "V"
  },
  {
   "start": 216.56,
   "end": 217.48,
   "text": "U"
  },
  {
   "start": 217.48,
   "end": 218.24,
   "text": "諧音"
  },
  {
   "start": 218.24,
   "end": 219.59,
   "text": "U"
  },
  {
   "start": 219.59,
   "end": 220.91,
   "text": "一個好名字"
  },
  {
   "start": 220.91,
   "end": 223.27,
   "text": "能把寶寶一路探討"
  },
  {
   "start": 223.27,
   "end": 224.39,
   "text": "真兩個字"
  },
  {
   "start": 224.39,
   "end": 225.99,
   "text": "切莫再用"
  },
  {
   "start": 225.99,
   "end": 227.91,
   "text": "所以這一次任天堂把概念"
  },
  {
   "start": 227.91,
   "end": 229.63,
   "text": "直接寫在了臉上"
  },
  {
   "start": 229.63,
   "end": 231.75,
   "text": "Switch切換"
  },
  {
   "start": 231.75,
   "end": 235.73,
   "text": "誰不懂"
  },
  {
   "start": 235.73,
   "end": 236.97,
   "text": "繼承了VU的一致"
  },
  {
   "start": 236.97,
   "end": 238.97,
   "text": "和他欠下的巨額債務"
  },
  {
   "start": 238.97,
   "end": 240.81,
   "text": "Switch就這樣誕生了"
  },
  {
   "start": 240.81,
   "end": 241.85,
   "text": "他肩負重任"
  },
  {
   "start": 241.85,
   "end": 244.41,
   "text": "他是任天堂堵上一切的背水一戰"
  },
  {
   "start": 244.41,
   "end": 245.57,
   "text": "我很佩服的一點是"
  },
  {
   "start": 245.57,
   "end": 247.21,
   "text": "即便VU如此失敗"
  },
  {
   "start": 247.21,
   "end": 248.89,
   "text": "即便PlayStation和Xbox"
  },
  {
   "start": 248.89,
   "end": 250.17,
   "text": "都在努力展示性能"
  },
  {
   "start": 250.17,
   "end": 252.57,
   "text": "證明自己可以更像PC的時候"
  },
  {
   "start": 252.57,
   "end": 254.09,
   "text": "任天堂始終相信"
  },
  {
   "start": 254.09,
   "end": 255.81,
   "text": "Switch切換的概念"
  },
  {
   "start": 255.81,
   "end": 257.57,
   "text": "同樣屬於此時代"
  },
  {
   "start": 257.57,
   "end": 258.21,
   "text": "很快"
  },
  {
   "start": 258.21,
   "end": 259.65,
   "text": "人們就都發現了"
  },
  {
   "start": 259.65,
   "end": 261.97,
   "text": "Switch不只是一台遊戲機"
  },
  {
   "start": 261.97,
   "end": 269.05,
   "text": "而是一場遊戲主機革命的開端"
  },
  {
   "start": 269.05,
   "end": 271.61,
   "text": "這個就是2017年的初版Switch"
  },
  {
   "start": 271.61,
   "end": 273.25,
   "text": "那個時候我還沒有開始做視頻"
  },
  {
   "start": 273.25,
   "end": 277.6,
   "text": "所以這是我第一次做它的開箱視頻"
  },
  {
   "start": 277.6,
   "end": 280.76,
   "text": "2025年開箱八年前的主機"
  },
  {
   "start": 280.76,
   "end": 284.03,
   "text": "說說我沒有開箱過這麼熟悉的東西"
  },
  {
   "start": 284.03,
   "end": 286.23,
   "text": "體型適中很輕盈"
  },
  {
   "start": 286.23,
   "end": 287.83,
   "text": "經典的紅藍配色"
  },
  {
   "start": 287.83,
   "end": 289.75,
   "text": "現在看還是很好看"
  },
  {
   "start": 289.75,
   "end": 291.67,
   "text": "現在我們對Switch性能的印象"
  },
  {
   "start": 291.67,
   "end": 293.55,
   "text": "可能是纏弱跟不上時代的"
  },
  {
   "start": 293.55,
   "end": 294.63,
   "text": "但在2017年"
  },
  {
   "start": 294.63,
   "end": 296.43,
   "text": "Tiger X1其實是這個價位"
  },
  {
   "start": 296.43,
   "end": 298.83,
   "text": "比較強大的移動平台芯片"
  },
  {
   "start": 298.83,
   "end": 299.75,
   "text": "Switch也是當時"
  },
  {
   "start": 299.75,
   "end": 302.11,
   "text": "絕對的最強性能掌機"
  },
  {
   "start": 302.11,
   "end": 304.19,
   "text": "雖然也沒有別的掌機了"
  },
  {
   "start": 304.19,
   "end": 306.47,
   "text": "加上任天堂自身強大的優化實力"
  },
  {
   "start": 306.47,
   "end": 308.19,
   "text": "和第三方廠商的不懈努力"
  },
  {
   "start": 308.19,
   "end": 309.79,
   "text": "Switch不僅能出色運行"
  },
  {
   "start": 309.79,
   "end": 310.87,
   "text": "像易度神劍2"
  },
  {
   "start": 310.87,
   "end": 312.15,
   "text": "火焰文章《風花雪月》"
  },
  {
   "start": 312.15,
   "end": 313.75,
   "text": "這樣複雜的3D大作"
  },
  {
   "start": 313.75,
   "end": 315.31,
   "text": "更是出現了像《霧石3》"
  },
  {
   "start": 315.31,
   "end": 316.03,
   "text": "對我們永恆"
  },
  {
   "start": 316.03,
   "end": 318.39,
   "text": "這樣技術奇蹟般的移植作品"
  },
  {
   "start": 318.39,
   "end": 320.67,
   "text": "在掌機上玩這麼大型的遊戲"
  },
  {
   "start": 320.67,
   "end": 321.79,
   "text": "真的很震撼"
  },
  {
   "start": 321.79,
   "end": 323.03,
   "text": "除了三種模式"
  },
  {
   "start": 323.03,
   "end": 325.83,
   "text": "這個Joy-Con可以說是Switch的精髓所在"
  },
  {
   "start": 325.83,
   "end": 327.23,
   "text": "HD震動 陀螺儀"
  },
  {
   "start": 327.23,
   "end": 328.51,
   "text": "加速器 紅外攝像頭"
  },
  {
   "start": 328.51,
   "end": 330.39,
   "text": "AFC芯片 全在裡面"
  },
  {
   "start": 330.39,
   "end": 332.23,
   "text": "不得不提的就是這個"
  },
  {
   "start": 332.23,
   "end": 334.11,
   "text": "會飄移的搖桿"
  },
  {
   "start": 334.11,
   "end": 335.43,
   "text": "要是2017年開箱"
  },
  {
   "start": 335.43,
   "end": 337.67,
   "text": "我可不知道你還有這麼毛病"
  },
  {
   "start": 338.47,
   "end": 340.47,
   "text": "當時在將近兩年的時間裡"
  },
  {
   "start": 340.47,
   "end": 342.59,
   "text": "大家買到的Joy-Con都很容易飄移"
  },
  {
   "start": 342.59,
   "end": 348.11,
   "text": "飄移起來就像這樣"
  },
  {
   "start": 348.11,
   "end": 350.27,
   "text": "搖桿有自己的想法"
  },
  {
   "start": 350.31,
   "end": 351.67,
   "text": "所以WG40"
  },
  {
   "start": 351.67,
   "end": 354.19,
   "text": "也成了當時Switch的常用配件之一"
  },
  {
   "start": 354.83,
   "end": 356.71,
   "text": "說回Joy-Con的正經功能"
  },
  {
   "start": 356.71,
   "end": 358.39,
   "text": "HD震動可以說是Switch"
  },
  {
   "start": 358.39,
   "end": 360.19,
   "text": "首發那會兒的主打功能"
  },
  {
   "start": 360.19,
   "end": 361.51,
   "text": "買了One to Switch的朋友"
  },
  {
   "start": 361.51,
   "end": 363.27,
   "text": "肯定記得拿著Joy-Con"
  },
  {
   "start": 363.27,
   "end": 365.63,
   "text": "感受裡面有即刻耕誅的感覺"
  },
  {
   "start": 367.41,
   "end": 368.69,
   "text": "陀螺儀和加速器"
  },
  {
   "start": 368.69,
   "end": 370.41,
   "text": "讓我們能夠玩體感遊戲"
  },
  {
   "start": 370.41,
   "end": 371.17,
   "text": "武力全開"
  },
  {
   "start": 371.17,
   "end": 371.85,
   "text": "遊玩拳擊"
  },
  {
   "start": 371.85,
   "end": 373.61,
   "text": "健身環大冒險"
  },
  {
   "start": 373.61,
   "end": 375.17,
   "text": "在Switch發售一年多"
  },
  {
   "start": 375.17,
   "end": 376.85,
   "text": "2018年4月的時候"
  },
  {
   "start": 376.85,
   "end": 378.89,
   "text": "Nintendo level正式推出"
  },
  {
   "start": 378.89,
   "end": 380.09,
   "text": "創意非常好"
  },
  {
   "start": 380.09,
   "end": 381.61,
   "text": "用紙板和Switch結合"
  },
  {
   "start": 381.61,
   "end": 383.01,
   "text": "利用紅外感應等功能"
  },
  {
   "start": 383.01,
   "end": 385.21,
   "text": "實現全新的DIY樂趣"
  },
  {
   "start": 385.21,
   "end": 386.41,
   "text": "比如彈鋼琴"
  },
  {
   "start": 386.41,
   "end": 386.89,
   "text": "釣魚"
  },
  {
   "start": 386.89,
   "end": 387.57,
   "text": "開摩托"
  },
  {
   "start": 387.57,
   "end": 388.13,
   "text": "喔"
  },
  {
   "start": 388.13,
   "end": 389.05,
   "text": "還有VR"
  },
  {
   "start": 391.27,
   "end": 392.15,
   "text": "Level VR"
  },
  {
   "start": 392.15,
   "end": 394.71,
   "text": "但是當年買了Level的朋友們"
  },
  {
   "start": 394.71,
   "end": 397.11,
   "text": "紙板子大概都降解了吧"
  },
  {
   "start": 397.11,
   "end": 398.51,
   "text": "我的也不例外"
  },
  {
   "start": 398.51,
   "end": 400.51,
   "text": "但是我會永遠記得Level"
  },
  {
   "start": 400.51,
   "end": 402.27,
   "text": "因為當年我在他發售一周內"
  },
  {
   "start": 402.27,
   "end": 403.31,
   "text": "就做了一個用Level"
  },
  {
   "start": 403.31,
   "end": 404.35,
   "text": "做成二壺的視頻"
  },
  {
   "start": 404.35,
   "end": 405.31,
   "text": "成為了我第一個"
  },
  {
   "start": 405.31,
   "end": 406.59,
   "text": "可以說是霍德的視頻"
  },
  {
   "start": 406.59,
   "end": 407.35,
   "text": "也讓我發現"
  },
  {
   "start": 407.35,
   "end": 408.43,
   "text": "做有意思的DIY"
  },
  {
   "start": 408.43,
   "end": 409.39,
   "text": "和有意思的視頻"
  },
  {
   "start": 409.39,
   "end": 410.83,
   "text": "真的很有意思"
  },
  {
   "start": 410.83,
   "end": 413.23,
   "text": "我永遠會感謝Level給我的啟發"
  },
  {
   "start": 413.23,
   "end": 413.99,
   "text": "謝謝你"
  },
  {
   "start": 416.24,
   "end": 417.52,
   "text": "不管有用沒用"
  },
  {
   "start": 417.52,
   "end": 418.88,
   "text": "這就是Switch"
  },
  {
   "start": 418.88,
   "end": 421.24,
   "text": "和他能夠做到那些有趣的事情"
  },
  {
   "start": 421.24,
   "end": 422.08,
   "text": "可想而知"
  },
  {
   "start": 422.08,
   "end": 424.64,
   "text": "這樣一個擁有18般5億的遊戲主機"
  },
  {
   "start": 424.64,
   "end": 426.28,
   "text": "在2017年3月3日"
  },
  {
   "start": 426.28,
   "end": 428.28,
   "text": "點燃了全球玩家的熱情"
  },
  {
   "start": 428.28,
   "end": 429.28,
   "text": "迅速受慶"
  },
  {
   "start": 429.28,
   "end": 430.92,
   "text": "此後長達半年的時間"
  },
  {
   "start": 430.92,
   "end": 432.6,
   "text": "Switch都嚴重斷貨"
  },
  {
   "start": 432.6,
   "end": 433.48,
   "text": "一級難求"
  },
  {
   "start": 437.33,
   "end": 438.53,
   "text": "最早一批Switch玩家"
  },
  {
   "start": 438.53,
   "end": 440.85,
   "text": "雖然玩到的遊戲數量並不算多"
  },
  {
   "start": 440.85,
   "end": 442.73,
   "text": "但如果搞一個世界上"
  },
  {
   "start": 442.73,
   "end": 444.41,
   "text": "最幸福玩家的評選"
  },
  {
   "start": 444.41,
   "end": 446.21,
   "text": "他們絕對能夠上榜"
  },
  {
   "start": 446.21,
   "end": 447.49,
   "text": "原因當然是任天堂"
  },
  {
   "start": 447.49,
   "end": 448.77,
   "text": "信心滿滿拿出來"
  },
  {
   "start": 448.77,
   "end": 451.65,
   "text": "為Switch保駕護航的那個遊戲"
  },
  {
   "start": 452.98,
   "end": 454.9,
   "text": "重新定義開放世界的"
  },
  {
   "start": 454.9,
   "end": 455.94,
   "text": "塞爾達傳說"
  },
  {
   "start": 455.94,
   "end": 457.02,
   "text": "曠野之西"
  },
  {
   "start": 457.3,
   "end": 458.18,
   "text": "很多朋友不知道"
  },
  {
   "start": 458.18,
   "end": 460.62,
   "text": "曠野之西其實是一個跨平台遊戲"
  },
  {
   "start": 460.62,
   "end": 462.94,
   "text": "它最早是針對VU平台開發的"
  },
  {
   "start": 462.94,
   "end": 464.46,
   "text": "但是老任的易男評"
  },
  {
   "start": 464.46,
   "end": 465.86,
   "text": "曠野之西爭氣地成為了"
  },
  {
   "start": 465.86,
   "end": 467.22,
   "text": "整個Switch生命週期"
  },
  {
   "start": 467.22,
   "end": 468.46,
   "text": "最偉大的遊戲"
  },
  {
   "start": 468.46,
   "end": 469.54,
   "text": "它也成功完成了"
  },
  {
   "start": 469.54,
   "end": 470.74,
   "text": "塞爾達傳說系列"
  },
  {
   "start": 470.74,
   "end": 472.54,
   "text": "在現代的華麗轉生"
  },
  {
   "start": 472.54,
   "end": 474.26,
   "text": "Metacritic評分97"
  },
  {
   "start": 474.26,
   "end": 476.3,
   "text": "之彼世界上評分最高的遊戲"
  },
  {
   "start": 476.3,
   "end": 477.98,
   "text": "99分的塞爾達傳說"
  },
  {
   "start": 477.98,
   "end": 480.26,
   "text": "實質敵以了2分不如使命"
  },
  {
   "start": 480.94,
   "end": 482.14,
   "text": "第一次玩曠野之西"
  },
  {
   "start": 482.14,
   "end": 483.46,
   "text": "你很容易就會覺得"
  },
  {
   "start": 483.46,
   "end": 484.26,
   "text": "哇世界上"
  },
  {
   "start": 484.26,
   "end": 485.74,
   "text": "怎麼還會有這樣的遊戲"
  },
  {
   "start": 485.74,
   "end": 487.66,
   "text": "這次我真的很想大膽開賣"
  },
  {
   "start": 487.66,
   "end": 489.26,
   "text": "在玩過王國之類之後"
  },
  {
   "start": 489.26,
   "end": 490.22,
   "text": "我更是認為"
  },
  {
   "start": 490.22,
   "end": 492.18,
   "text": "原本可能是無意做出的"
  },
  {
   "start": 492.18,
   "end": 493.74,
   "text": "那些難以攀登的高山"
  },
  {
   "start": 493.74,
   "end": 494.86,
   "text": "和荒蕪的曠野"
  },
  {
   "start": 494.86,
   "end": 497.1,
   "text": "是這個遊戲最有靈魂的部分"
  },
  {
   "start": 497.1,
   "end": 498.9,
   "text": "我很喜歡那種孤單的氛圍"
  },
  {
   "start": 498.9,
   "end": 500.42,
   "text": "和獨自冒險的氣質"
  },
  {
   "start": 500.5,
   "end": 502.06,
   "text": "我永遠感謝這個遊戲"
  },
  {
   "start": 502.06,
   "end": 503.58,
   "text": "因為曠野之西確確實實的"
  },
  {
   "start": 503.58,
   "end": 505.58,
   "text": "陪我走過了人生最灰暗的階段"
  },
  {
   "start": 505.58,
   "end": 507.9,
   "text": "給我內心帶來了平靜和寬衛"
  },
  {
   "start": 508.7,
   "end": 510.66,
   "text": "被海拉路自由的威風吹過"
  },
  {
   "start": 510.66,
   "end": 512.38,
   "text": "真的很難換過勁兒來"
  },
  {
   "start": 512.38,
   "end": 514.22,
   "text": "如果你是第一時間買到了Switch"
  },
  {
   "start": 514.22,
   "end": 516.3,
   "text": "又是第一時間玩到了曠野之西"
  },
  {
   "start": 516.3,
   "end": 517.74,
   "text": "那之後的半年"
  },
  {
   "start": 517.74,
   "end": 519.1,
   "text": "我相信你應該是"
  },
  {
   "start": 519.1,
   "end": 520.42,
   "text": "被趕空虛"
  },
  {
   "start": 522.95,
   "end": 529.62,
   "text": "空虛到"
  },
  {
   "start": 529.62,
   "end": 530.54,
   "text": "把鏟子騎士"
  },
  {
   "start": 530.54,
   "end": 531.3,
   "text": "One to Switch"
  },
  {
   "start": 531.3,
   "end": 531.9,
   "text": "和炸彈人"
  },
  {
   "start": 531.9,
   "end": 532.86,
   "text": "都玩到包僵"
  },
  {
   "start": 532.86,
   "end": 533.94,
   "text": "或是包著Switch上"
  },
  {
   "start": 533.94,
   "end": 535.22,
   "text": "銷量最高的遊戲"
  },
  {
   "start": 535.22,
   "end": 535.98,
   "text": "馬車巴"
  },
  {
   "start": 535.98,
   "end": 537.14,
   "text": "一圈一圈的跑"
  },
  {
   "start": 537.14,
   "end": 538.1,
   "text": "直到10月"
  },
  {
   "start": 538.1,
   "end": 539.62,
   "text": "任天堂第一大IP"
  },
  {
   "start": 539.62,
   "end": 541.54,
   "text": "馬里奧真正發力了"
  },
  {
   "start": 541.54,
   "end": 544.02,
   "text": "超級馬里奧奧德賽華麗登場"
  },
  {
   "start": 544.02,
   "end": 545.46,
   "text": "同樣的97分"
  },
  {
   "start": 545.46,
   "end": 547.38,
   "text": "非常現代的全面3D畫"
  },
  {
   "start": 547.38,
   "end": 548.86,
   "text": "卓越的平台跳躍玩法"
  },
  {
   "start": 548.86,
   "end": 550.14,
   "text": "和精妙的關卡設計"
  },
  {
   "start": 550.14,
   "end": 551.06,
   "text": "把馬里奧系列"
  },
  {
   "start": 551.06,
   "end": 552.9,
   "text": "抬到了一個新的高度"
  },
  {
   "start": 555.91,
   "end": 556.39,
   "text": "說起來"
  },
  {
   "start": 556.39,
   "end": 558.23,
   "text": "2017可真是遊戲大年"
  },
  {
   "start": 558.23,
   "end": 559.67,
   "text": "除了這些傳世家座"
  },
  {
   "start": 559.67,
   "end": 560.47,
   "text": "《噴射戰十二》"
  },
  {
   "start": 560.47,
   "end": 561.23,
   "text": "《一度神劍二》"
  },
  {
   "start": 561.23,
   "end": 562.27,
   "text": "也是那年的遊戲"
  },
  {
   "start": 562.27,
   "end": 563.35,
   "text": "還有胡鬧廚房"
  },
  {
   "start": 563.35,
   "end": 565.27,
   "text": "簡直是為自帶兩手柄的Switch"
  },
  {
   "start": 565.27,
   "end": 566.27,
   "text": "量身訂作"
  },
  {
   "start": 566.27,
   "end": 567.67,
   "text": "為Switch走進大眾"
  },
  {
   "start": 567.67,
   "end": 568.39,
   "text": "走進家庭"
  },
  {
   "start": 568.39,
   "end": 569.23,
   "text": "開了個好童"
  },
  {
   "start": 569.23,
   "end": 570.35,
   "text": "而且你敢想嗎"
  },
  {
   "start": 570.35,
   "end": 572.39,
   "text": "那年的TGA年度遊戲提名"
  },
  {
   "start": 572.39,
   "end": 573.79,
   "text": "除了《跨遠之西》和奧德賽"
  },
  {
   "start": 573.79,
   "end": 574.51,
   "text": "還有"
  },
  {
   "start": 574.51,
   "end": 575.79,
   "text": "地平前鄰之曙光"
  },
  {
   "start": 575.79,
   "end": 576.47,
   "text": "POPG"
  },
  {
   "start": 576.47,
   "end": 577.95,
   "text": "和女神一聞入霧"
  },
  {
   "start": 577.95,
   "end": 579.47,
   "text": "真正的神仙大家"
  },
  {
   "start": 579.47,
   "end": 580.63,
   "text": "太開心了"
  },
  {
   "start": 580.63,
   "end": 581.67,
   "text": "到了1819年"
  },
  {
   "start": 581.67,
   "end": 582.83,
   "text": "Switch的遊戲陣容"
  },
  {
   "start": 582.83,
   "end": 585.15,
   "text": "明顯開始往更多方向去嘗試"
  },
  {
   "start": 585.15,
   "end": 586.55,
   "text": "進一步打開市場"
  },
  {
   "start": 586.55,
   "end": 587.11,
   "text": "大亂鬥"
  },
  {
   "start": 587.11,
   "end": 588.15,
   "text": "靠著童年回憶"
  },
  {
   "start": 588.15,
   "end": 589.67,
   "text": "成功拿下北美玩家"
  },
  {
   "start": 589.67,
   "end": 591.23,
   "text": "寶可夢見盾和屈皮屈衣"
  },
  {
   "start": 591.23,
   "end": 592.15,
   "text": "依次掏空"
  },
  {
   "start": 592.15,
   "end": 594.11,
   "text": "暴迷和動畫觀眾的錢包"
  },
  {
   "start": 594.11,
   "end": 594.91,
   "text": "這個精靈球"
  },
  {
   "start": 594.91,
   "end": 596.95,
   "text": "絕對是最佳外設之一"
  },
  {
   "start": 596.95,
   "end": 598.63,
   "text": "馬趴進一步打開Switch"
  },
  {
   "start": 598.63,
   "end": 600.11,
   "text": "和家歡的社交屬性"
  },
  {
   "start": 600.11,
   "end": 600.63,
   "text": "健身環"
  },
  {
   "start": 600.63,
   "end": 601.31,
   "text": "有氧全機"
  },
  {
   "start": 601.31,
   "end": 602.35,
   "text": "給了很多家庭"
  },
  {
   "start": 602.35,
   "end": 603.11,
   "text": "一個把Switch"
  },
  {
   "start": 603.11,
   "end": 604.87,
   "text": "常放在電視機旁的理由"
  },
  {
   "start": 604.87,
   "end": 605.95,
   "text": "未來和空洞騎士"
  },
  {
   "start": 605.95,
   "end": 607.63,
   "text": "讓核心玩家發現Switch"
  },
  {
   "start": 607.63,
   "end": 608.75,
   "text": "是個多麼適合玩"
  },
  {
   "start": 608.75,
   "end": 610.63,
   "text": "獨立遊戲的完美遊戲機"
  },
  {
   "start": 612.06,
   "end": 613.42,
   "text": "雖然不是手法"
  },
  {
   "start": 613.42,
   "end": 615.42,
   "text": "但我自己也是在比較早的時候"
  },
  {
   "start": 615.42,
   "end": 616.5,
   "text": "一起年下半年"
  },
  {
   "start": 616.5,
   "end": 618.74,
   "text": "擁有了我的第一台Switch"
  },
  {
   "start": 618.74,
   "end": 621.22,
   "text": "我從最Gimicky的小遊戲開始"
  },
  {
   "start": 621.22,
   "end": 622.06,
   "text": "慢慢嘗試了"
  },
  {
   "start": 622.06,
   "end": 623.62,
   "text": "所有我感興趣的遊戲"
  },
  {
   "start": 623.62,
   "end": 625.74,
   "text": "那時候Switch就像是我的小寵物"
  },
  {
   "start": 625.74,
   "end": 627.06,
   "text": "睡覺也要放在床邊"
  },
  {
   "start": 627.06,
   "end": 627.66,
   "text": "陪著我"
  },
  {
   "start": 628.79,
   "end": 629.95,
   "text": "受到產業限制"
  },
  {
   "start": 629.95,
   "end": 630.95,
   "text": "整個2017年"
  },
  {
   "start": 630.95,
   "end": 632.15,
   "text": "任天堂一共賣出了"
  },
  {
   "start": 632.15,
   "end": 633.47,
   "text": "1000萬台Switch"
  },
  {
   "start": 633.47,
   "end": 634.67,
   "text": "市場表現這麼好"
  },
  {
   "start": 634.67,
   "end": 636.35,
   "text": "任天堂立刻大量鋪貨"
  },
  {
   "start": 636.35,
   "end": 637.11,
   "text": "推出三年"
  },
  {
   "start": 637.11,
   "end": 638.39,
   "text": "小量蹭蹭往上漲"
  },
  {
   "start": 638.39,
   "end": 639.27,
   "text": "還在2019年"
  },
  {
   "start": 639.27,
   "end": 640.43,
   "text": "陸續推出更新的"
  },
  {
   "start": 640.43,
   "end": 641.23,
   "text": "長續航版"
  },
  {
   "start": 641.23,
   "end": 642.07,
   "text": "和更便協的"
  },
  {
   "start": 642.07,
   "end": 643.67,
   "text": "純漲機Switch Lite"
  },
  {
   "start": 643.67,
   "end": 645.11,
   "text": "雖然賣的是真好"
  },
  {
   "start": 645.11,
   "end": 646.27,
   "text": "但在這段時間裡"
  },
  {
   "start": 646.27,
   "end": 647.35,
   "text": "Switch也爆出了"
  },
  {
   "start": 647.35,
   "end": 648.71,
   "text": "它整個生命週期裡"
  },
  {
   "start": 648.71,
   "end": 649.63,
   "text": "最大的醜聞"
  },
  {
   "start": 649.63,
   "end": 650.47,
   "text": "就是一開始"
  },
  {
   "start": 650.47,
   "end": 651.83,
   "text": "我們當回憶獎的"
  },
  {
   "start": 651.83,
   "end": 653.11,
   "text": "搖桿飄移"
  },
  {
   "start": 653.11,
   "end": 654.79,
   "text": "集體訴訟事件"
  },
  {
   "start": 654.79,
   "end": 656.23,
   "text": "發售後的首批Joycom"
  },
  {
   "start": 656.23,
   "end": 657.03,
   "text": "在幾個月內"
  },
  {
   "start": 657.03,
   "end": 658.35,
   "text": "陸續被報告出現"
  },
  {
   "start": 658.35,
   "end": 659.31,
   "text": "飄移現象"
  },
  {
   "start": 659.31,
   "end": 661.07,
   "text": "比例高達5分之2"
  },
  {
   "start": 661.07,
   "end": 662.31,
   "text": "其中超過一半的人"
  },
  {
   "start": 662.31,
   "end": 662.99,
   "text": "在購買主機"
  },
  {
   "start": 662.99,
   "end": 663.83,
   "text": "不到一年內"
  },
  {
   "start": 663.83,
   "end": 664.75,
   "text": "就開始出現"
  },
  {
   "start": 664.75,
   "end": 665.83,
   "text": "搖桿飄移了"
  },
  {
   "start": 665.83,
   "end": 666.51,
   "text": "雖然任天堂"
  },
  {
   "start": 666.51,
   "end": 668.79,
   "text": "其實一直在對搖桿的零件"
  },
  {
   "start": 668.79,
   "end": 670.07,
   "text": "做不斷改良"
  },
  {
   "start": 670.07,
   "end": 671.23,
   "text": "這個故障比例"
  },
  {
   "start": 671.23,
   "end": 672.31,
   "text": "似乎隨著時間"
  },
  {
   "start": 672.31,
   "end": 673.79,
   "text": "也有在慢慢下降"
  },
  {
   "start": 673.79,
   "end": 675.55,
   "text": "但直到Switch Lite發售"
  },
  {
   "start": 675.55,
   "end": 676.55,
   "text": "也還是爆出了"
  },
  {
   "start": 676.55,
   "end": 678.03,
   "text": "搖桿飄移的問題"
  },
  {
   "start": 678.03,
   "end": 678.63,
   "text": "這個事件"
  },
  {
   "start": 678.63,
   "end": 679.91,
   "text": "在國外鬧得很大"
  },
  {
   "start": 679.91,
   "end": 680.67,
   "text": "因為在早期"
  },
  {
   "start": 680.67,
   "end": 682.39,
   "text": "任天堂從未正式承認過"
  },
  {
   "start": 682.39,
   "end": 683.75,
   "text": "搖桿飄移存在"
  },
  {
   "start": 683.75,
   "end": 685.39,
   "text": "產品設計有缺陷"
  },
  {
   "start": 685.39,
   "end": 686.15,
   "text": "這樣的態度"
  },
  {
   "start": 686.15,
   "end": 688.07,
   "text": "肯定不能夠讓玩家們滿意"
  },
  {
   "start": 688.07,
   "end": 689.67,
   "text": "北美地區和歐洲的消費者"
  },
  {
   "start": 689.67,
   "end": 690.63,
   "text": "開始對任天堂"
  },
  {
   "start": 690.63,
   "end": 692.47,
   "text": "發起集體訴訟和投訴"
  },
  {
   "start": 692.47,
   "end": 693.51,
   "text": "但大家也知道"
  },
  {
   "start": 693.51,
   "end": 694.55,
   "text": "打官司維權"
  },
  {
   "start": 694.55,
   "end": 696.07,
   "text": "向來是費時又費力的"
  },
  {
   "start": 696.07,
   "end": 697.59,
   "text": "何況對手還是東半球"
  },
  {
   "start": 697.59,
   "end": 698.79,
   "text": "最強法務部"
  },
  {
   "start": 698.79,
   "end": 700.55,
   "text": "這些投訴和訴訟案件"
  },
  {
   "start": 700.55,
   "end": 701.87,
   "text": "最終在鄰近Switch"
  },
  {
   "start": 701.87,
   "end": 703.03,
   "text": "生命默契的幾年"
  },
  {
   "start": 703.03,
   "end": 704.39,
   "text": "才塵埃落定"
  },
  {
   "start": 704.39,
   "end": 705.03,
   "text": "大家知道"
  },
  {
   "start": 705.03,
   "end": 706.31,
   "text": "結果是什麼嗎"
  },
  {
   "start": 706.31,
   "end": 707.27,
   "text": "日本和歐洲"
  },
  {
   "start": 707.27,
   "end": 708.55,
   "text": "多虧了消費者投訴"
  },
  {
   "start": 708.55,
   "end": 709.55,
   "text": "人多力量大"
  },
  {
   "start": 709.55,
   "end": 710.75,
   "text": "任天堂在2023年"
  },
  {
   "start": 710.75,
   "end": 712.59,
   "text": "終於一點點做出了讓步"
  },
  {
   "start": 712.59,
   "end": 713.59,
   "text": "承諾對Joycom"
  },
  {
   "start": 713.59,
   "end": 715.87,
   "text": "提供免費無限期的維修服務"
  },
  {
   "start": 715.91,
   "end": 716.75,
   "text": "美國那邊"
  },
  {
   "start": 716.75,
   "end": 718.83,
   "text": "在19年出現集體訴訟之後"
  },
  {
   "start": 718.83,
   "end": 720.19,
   "text": "任天堂小硬迅速"
  },
  {
   "start": 720.19,
   "end": 722.23,
   "text": "悄迷迷修改了維修政策"
  },
  {
   "start": 722.23,
   "end": 723.59,
   "text": "但那些訴訟案件"
  },
  {
   "start": 723.59,
   "end": 725.71,
   "text": "任天堂可是一個牙縫都沒鬆"
  },
  {
   "start": 725.71,
   "end": 727.27,
   "text": "均已撤訴告終"
  },
  {
   "start": 727.27,
   "end": 728.63,
   "text": "以無聲落幕"
  },
  {
   "start": 728.63,
   "end": 730.27,
   "text": "至於其他地區"
  },
  {
   "start": 730.27,
   "end": 731.27,
   "text": "得到的主要是"
  },
  {
   "start": 731.27,
   "end": 732.99,
   "text": "任天堂總裁谷川俊太郎"
  },
  {
   "start": 732.99,
   "end": 735.79,
   "text": "在股東與財務問答中的道歉"
  },
  {
   "start": 735.79,
   "end": 737.03,
   "text": "對於Joycom手柄"
  },
  {
   "start": 737.03,
   "end": 738.39,
   "text": "給顧客造成的不變"
  },
  {
   "start": 738.39,
   "end": 739.71,
   "text": "我們深表歉意"
  },
  {
   "start": 739.71,
   "end": 741.99,
   "text": "我們會繼續改良產品"
  },
  {
   "start": 741.99,
   "end": 743.91,
   "text": "雖然是面向股東的"
  },
  {
   "start": 743.91,
   "end": 745.75,
   "text": "但是我們也可以理解為"
  },
  {
   "start": 745.75,
   "end": 747.79,
   "text": "是正面回應和道歉了"
  },
  {
   "start": 748.31,
   "end": 752.61,
   "text": "大家不用為沒有官方維修而傷心"
  },
  {
   "start": 752.61,
   "end": 753.53,
   "text": "因為很快"
  },
  {
   "start": 753.53,
   "end": 755.53,
   "text": "2019年12月10日"
  },
  {
   "start": 755.53,
   "end": 756.85,
   "text": "國航Switch"
  },
  {
   "start": 756.85,
   "end": 761.74,
   "text": "它來了"
  },
  {
   "start": 761.74,
   "end": 764.1,
   "text": "異商店跟其他人長得都不一樣"
  },
  {
   "start": 764.1,
   "end": 765.54,
   "text": "但可以登錄微信"
  },
  {
   "start": 765.54,
   "end": 767.86,
   "text": "看騰訊視頻的閹割版Switch"
  },
  {
   "start": 767.86,
   "end": 769.7,
   "text": "不管我們怎麼挑砍它"
  },
  {
   "start": 769.7,
   "end": 771.02,
   "text": "不可否認的是"
  },
  {
   "start": 771.02,
   "end": 772.62,
   "text": "國航Switch進入中國"
  },
  {
   "start": 772.62,
   "end": 775.38,
   "text": "還是為Switch拉攏了一大批新用戶"
  },
  {
   "start": 775.38,
   "end": 777.42,
   "text": "當時街邊商場裡"
  },
  {
   "start": 777.42,
   "end": 779.5,
   "text": "都能經常看到Switch的實體店"
  },
  {
   "start": 779.5,
   "end": 782.1,
   "text": "Switch也頻繁在各種綜藝裡露出"
  },
  {
   "start": 782.1,
   "end": 784.7,
   "text": "當然還有那支非常出圈的廣告"
  },
  {
   "start": 786.14,
   "end": 788.06,
   "text": "一時間Switch就從遊戲機"
  },
  {
   "start": 788.06,
   "end": 789.5,
   "text": "變成了時尚單品"
  },
  {
   "start": 789.5,
   "end": 791.34,
   "text": "帶出門又酷又有份"
  },
  {
   "start": 791.34,
   "end": 793.26,
   "text": "再後來疫情來了"
  },
  {
   "start": 793.26,
   "end": 795.54,
   "text": "這對全世界各個國家和企業來說"
  },
  {
   "start": 795.54,
   "end": 796.98,
   "text": "都是一場巨大的災難"
  },
  {
   "start": 796.98,
   "end": 799.54,
   "text": "但是Switch又一次崛起了"
  },
  {
   "start": 799.54,
   "end": 800.74,
   "text": "靠著動物森友會"
  },
  {
   "start": 800.74,
   "end": 803.34,
   "text": "在全球範圍內都再火了一把"
  },
  {
   "start": 803.34,
   "end": 804.5,
   "text": "20年的全年銷量"
  },
  {
   "start": 804.5,
   "end": 806.22,
   "text": "也出現了一個小小的高峰"
  },
  {
   "start": 806.22,
   "end": 806.82,
   "text": "動森"
  },
  {
   "start": 806.82,
   "end": 808.22,
   "text": "真的是我在這個地球上"
  },
  {
   "start": 808.22,
   "end": 809.7,
   "text": "最喜歡的遊戲之一"
  },
  {
   "start": 809.7,
   "end": 811.06,
   "text": "那個時候我把我Switch"
  },
  {
   "start": 811.06,
   "end": 813.34,
   "text": "300個好友上線全都加滿了"
  },
  {
   "start": 813.34,
   "end": 815.34,
   "text": "加的全是粉絲朋友們"
  },
  {
   "start": 815.34,
   "end": 817.02,
   "text": "當時我只要一打開Switch"
  },
  {
   "start": 817.02,
   "end": 818.78,
   "text": "就能看到好多好友在線"
  },
  {
   "start": 818.78,
   "end": 821.42,
   "text": "幾十個人同時在線都是非常正常的"
  },
  {
   "start": 821.42,
   "end": 823.95,
   "text": "但是現在你看"
  },
  {
   "start": 823.95,
   "end": 824.99,
   "text": "沒有"
  },
  {
   "start": 824.99,
   "end": 825.59,
   "text": "出院了"
  },
  {
   "start": 825.59,
   "end": 828.31,
   "text": "動森在我們所有人都比較艱難的時候"
  },
  {
   "start": 828.31,
   "end": 830.99,
   "text": "提供了一個可以逃離現實的世外桃源"
  },
  {
   "start": 830.99,
   "end": 832.23,
   "text": "達成都督航空"
  },
  {
   "start": 832.23,
   "end": 834.63,
   "text": "去朋友的小島一起等流星劃過"
  },
  {
   "start": 834.63,
   "end": 835.59,
   "text": "雖然沒有素材"
  },
  {
   "start": 835.59,
   "end": 837.07,
   "text": "但我打出這段話的時候"
  },
  {
   "start": 837.07,
   "end": 838.15,
   "text": "不爭氣地哭了"
  },
  {
   "start": 838.15,
   "end": 839.27,
   "text": "如果不主動回顧"
  },
  {
   "start": 839.27,
   "end": 840.31,
   "text": "我都無法意識到"
  },
  {
   "start": 840.31,
   "end": 842.39,
   "text": "我曾經有過這麼幸福的時代"
  },
  {
   "start": 843.5,
   "end": 845.42,
   "text": "從2021年開始的故事"
  },
  {
   "start": 845.42,
   "end": 847.14,
   "text": "大家就都比較熟悉了"
  },
  {
   "start": 847.14,
   "end": 849.34,
   "text": "Switch的銷量增速開始放緩"
  },
  {
   "start": 849.34,
   "end": 850.42,
   "text": "世代過半"
  },
  {
   "start": 850.42,
   "end": 851.58,
   "text": "相對家用機來說"
  },
  {
   "start": 851.58,
   "end": 853.98,
   "text": "並不強勁的性能開始捉襟見軸"
  },
  {
   "start": 853.98,
   "end": 856.42,
   "text": "任天堂選擇推出OLED版Switch"
  },
  {
   "start": 856.42,
   "end": 856.98,
   "text": "但因為"
  },
  {
   "start": 856.98,
   "end": 858.18,
   "text": "並不是大家所期待的"
  },
  {
   "start": 858.18,
   "end": 860.06,
   "text": "性能提升的Pro機型"
  },
  {
   "start": 860.06,
   "end": 862.5,
   "text": "所以也並沒能提起玩家們的熱情"
  },
  {
   "start": 863.1,
   "end": 867.19,
   "text": "吃灰開始成為大家提到Switch"
  },
  {
   "start": 867.19,
   "end": 868.43,
   "text": "最先想到的詞"
  },
  {
   "start": 868.43,
   "end": 871.19,
   "text": "甚至有人開始用電子垃圾這樣的詞彙"
  },
  {
   "start": 871.19,
   "end": 872.39,
   "text": "來形容Switch"
  },
  {
   "start": 872.39,
   "end": 875.11,
   "text": "但其實在我整理遊戲陣容的時候發現"
  },
  {
   "start": 875.11,
   "end": 876.31,
   "text": "世代墨西的Switch"
  },
  {
   "start": 876.31,
   "end": 877.31,
   "text": "還是給我們帶來了"
  },
  {
   "start": 877.31,
   "end": 878.67,
   "text": "不少好玩的遊戲"
  },
  {
   "start": 878.67,
   "end": 880.23,
   "text": "21年有怪獵崛起"
  },
  {
   "start": 880.23,
   "end": 881.79,
   "text": "22年有異度神劍3"
  },
  {
   "start": 881.79,
   "end": 883.51,
   "text": "彭射戰士3和兩個寶可夢"
  },
  {
   "start": 883.51,
   "end": 885.51,
   "text": "23年有王國之類和馬寮驚奇"
  },
  {
   "start": 885.51,
   "end": 887.03,
   "text": "24年有銀河戰士"
  },
  {
   "start": 887.03,
   "end": 887.87,
   "text": "說實話"
  },
  {
   "start": 887.87,
   "end": 888.71,
   "text": "都這會了"
  },
  {
   "start": 888.71,
   "end": 889.95,
   "text": "有點遊戲玩得不錯了"
  },
  {
   "start": 889.95,
   "end": 890.87,
   "text": "還吃灰呢"
  },
  {
   "start": 890.87,
   "end": 892.03,
   "text": "吃土了都快"
  },
  {
   "start": 894.57,
   "end": 896.61,
   "text": "時間終於來到了現在"
  },
  {
   "start": 896.61,
   "end": 897.77,
   "text": "2025年"
  },
  {
   "start": 897.77,
   "end": 899.29,
   "text": "如果我們把視角拉遠"
  },
  {
   "start": 899.29,
   "end": 901.89,
   "text": "去看這8年來Switch帶給我們的遊戲"
  },
  {
   "start": 901.89,
   "end": 902.69,
   "text": "你會發現"
  },
  {
   "start": 902.69,
   "end": 904.57,
   "text": "不論是跟本世代的PS5"
  },
  {
   "start": 904.57,
   "end": 906.09,
   "text": "還是上世代的PS4比"
  },
  {
   "start": 906.09,
   "end": 908.17,
   "text": "Switch都提供了數量更多的"
  },
  {
   "start": 908.17,
   "end": 910.89,
   "text": "必玩大作和值得一玩的優質遊戲"
  },
  {
   "start": 910.89,
   "end": 913.01,
   "text": "如果把視角再拉遠一點"
  },
  {
   "start": 913.01,
   "end": 915.85,
   "text": "Switch對這個世代遊戲主機世界的影響"
  },
  {
   "start": 915.85,
   "end": 916.93,
   "text": "是不可磨滅的"
  },
  {
   "start": 916.93,
   "end": 918.61,
   "text": "在Switch剛推出那會"
  },
  {
   "start": 918.61,
   "end": 920.21,
   "text": "由於手機非速進化"
  },
  {
   "start": 920.21,
   "end": 922.05,
   "text": "手遊搶奪了掌機的地盤"
  },
  {
   "start": 922.05,
   "end": 924.33,
   "text": "索尼已經退出掌機市場了"
  },
  {
   "start": 924.33,
   "end": 926.41,
   "text": "是Switch對掌機形態的堅持"
  },
  {
   "start": 926.41,
   "end": 928.05,
   "text": "重新打開了這個市場"
  },
  {
   "start": 928.05,
   "end": 929.73,
   "text": "這些年我們都能夠感知到"
  },
  {
   "start": 929.73,
   "end": 931.97,
   "text": "各大廠商跟隨著Switch的步伐"
  },
  {
   "start": 931.97,
   "end": 933.69,
   "text": "陸續推出自己的掌機"
  },
  {
   "start": 933.69,
   "end": 934.69,
   "text": "百花齊放"
  },
  {
   "start": 934.69,
   "end": 937.01,
   "text": "裡面最矚目的當屬Steam Deck"
  },
  {
   "start": 937.01,
   "end": 939.21,
   "text": "可以說到Switch開始吃灰"
  },
  {
   "start": 939.21,
   "end": 940.49,
   "text": "Steam Deck就成了"
  },
  {
   "start": 940.49,
   "end": 942.89,
   "text": "重度遊戲愛好者們的新選擇"
  },
  {
   "start": 942.89,
   "end": 944.89,
   "text": "除了救活遊戲掌機產業"
  },
  {
   "start": 944.89,
   "end": 945.81,
   "text": "神醫Switch"
  },
  {
   "start": 945.81,
   "end": 948.61,
   "text": "還一舉救活了家庭遊戲這個概念"
  },
  {
   "start": 948.61,
   "end": 950.33,
   "text": "仔細想想以前的遊戲機"
  },
  {
   "start": 950.33,
   "end": 952.13,
   "text": "買來就是送兩手柄的"
  },
  {
   "start": 952.13,
   "end": 954.17,
   "text": "原裝就可以家裡兩個人一起玩"
  },
  {
   "start": 954.17,
   "end": 956.53,
   "text": "但是這個傳統慢慢就消失了"
  },
  {
   "start": 956.53,
   "end": 957.69,
   "text": "直到Switch出來"
  },
  {
   "start": 957.73,
   "end": 959.73,
   "text": "用Joy-Con給他心臟復甦了"
  },
  {
   "start": 959.73,
   "end": 960.81,
   "text": "也多虧了這一點"
  },
  {
   "start": 960.81,
   "end": 963.37,
   "text": "更多的人才開始接觸主機遊戲"
  },
  {
   "start": 963.37,
   "end": 963.85,
   "text": "哦"
  },
  {
   "start": 963.85,
   "end": 965.57,
   "text": "如果妳好奇Switch這個銷量"
  },
  {
   "start": 965.57,
   "end": 966.89,
   "text": "到底是什麼水平"
  },
  {
   "start": 966.89,
   "end": 969.01,
   "text": "我只能說其他所有掌機"
  },
  {
   "start": 969.01,
   "end": 971.69,
   "text": "完全無法撼動Switch的地位"
  },
  {
   "start": 971.69,
   "end": 975.17,
   "text": "面對Switch超過1.5億台的銷量數據"
  },
  {
   "start": 975.17,
   "end": 976.49,
   "text": "包含Steam Deck"
  },
  {
   "start": 976.49,
   "end": 977.41,
   "text": "LG Ally"
  },
  {
   "start": 977.41,
   "end": 980.09,
   "text": "Legend Go在內的整個PC掌機市場"
  },
  {
   "start": 980.09,
   "end": 983.13,
   "text": "它們加起來的出貨量是不到600萬台"
  },
  {
   "start": 983.13,
   "end": 985.77,
   "text": "是Switch總銷量的25分之一"
  },
  {
   "start": 985.77,
   "end": 987.37,
   "text": "完全是被淹沒的程度"
  },
  {
   "start": 987.45,
   "end": 989.69,
   "text": "如果我們再認真對比一下銷量"
  },
  {
   "start": 989.69,
   "end": 990.93,
   "text": "那就更有意思了"
  },
  {
   "start": 990.93,
   "end": 994.09,
   "text": "目前銷量第一的遊戲主機是PS2"
  },
  {
   "start": 994.09,
   "end": 995.97,
   "text": "賣出了超過1.6億台"
  },
  {
   "start": 995.97,
   "end": 997.05,
   "text": "在這八年裡"
  },
  {
   "start": 997.05,
   "end": 998.89,
   "text": "Switch每次刷新銷量"
  },
  {
   "start": 998.89,
   "end": 1000.41,
   "text": "逼近PS2的時候"
  },
  {
   "start": 1000.41,
   "end": 1002.41,
   "text": "已經退市十幾年的PS2"
  },
  {
   "start": 1002.41,
   "end": 1004.37,
   "text": "都會神奇的多賣出幾台"
  },
  {
   "start": 1004.37,
   "end": 1005.81,
   "text": "索尼也會冠選一次"
  },
  {
   "start": 1005.81,
   "end": 1007.89,
   "text": "自己最新的銷量戰報"
  },
  {
   "start": 1007.89,
   "end": 1010.73,
   "text": "和Switch保持一個禮貌的距離"
  },
  {
   "start": 1010.73,
   "end": 1011.21,
   "text": "當然"
  },
  {
   "start": 1011.21,
   "end": 1013.05,
   "text": "不管是銷量冠軍還是技軍"
  },
  {
   "start": 1013.05,
   "end": 1014.25,
   "text": "不可否認的是"
  },
  {
   "start": 1014.25,
   "end": 1016.41,
   "text": "Switch的市場反饋和遊戲陣容"
  },
  {
   "start": 1016.41,
   "end": 1020.49,
   "text": "其實已經可以和一代神機PS2分庭抗禮"
  },
  {
   "start": 1020.49,
   "end": 1021.41,
   "text": "再過幾年"
  },
  {
   "start": 1021.41,
   "end": 1024.41,
   "text": "Switch也會積極實實地成為一代人的回憶"
  },
  {
   "start": 1024.41,
   "end": 1026.41,
   "text": "我們因為各種契機跟它結緣"
  },
  {
   "start": 1026.41,
   "end": 1029.17,
   "text": "它見證了我們和家人朋友的美好時刻"
  },
  {
   "start": 1029.17,
   "end": 1030.29,
   "text": "也曾用一款遊戲"
  },
  {
   "start": 1030.29,
   "end": 1032.49,
   "text": "永遠佔據著我們回憶的一角"
  },
  {
   "start": 1032.49,
   "end": 1034.33,
   "text": "Switch2已經公佈了"
  },
  {
   "start": 1034.33,
   "end": 1036.13,
   "text": "Switch已經可以改口"
  },
  {
   "start": 1036.13,
   "end": 1037.33,
   "text": "叫它Switch1了"
  },
  {
   "start": 1037.33,
   "end": 1038.49,
   "text": "回看這八年"
  },
  {
   "start": 1038.49,
   "end": 1039.29,
   "text": "預算家裡"
  },
  {
   "start": 1039.29,
   "end": 1041.25,
   "text": "PlayStation還在被迫和Xbox"
  },
  {
   "start": 1041.25,
   "end": 1043.25,
   "text": "內卷性能比拼肌肉力量"
  },
  {
   "start": 1043.25,
   "end": 1045.29,
   "text": "Xbox約等於半退賽"
  },
  {
   "start": 1045.29,
   "end": 1047.37,
   "text": "而Switch既保留了從B開始的"
  },
  {
   "start": 1047.37,
   "end": 1048.89,
   "text": "整合式X一花競爭"
  },
  {
   "start": 1048.89,
   "end": 1051.25,
   "text": "又重新贏得了第三方廠商的支持"
  },
  {
   "start": 1051.25,
   "end": 1054.01,
   "text": "在自己給自己開闢的單車道賽道上"
  },
  {
   "start": 1054.01,
   "end": 1055.65,
   "text": "自己挑戰的自己"
  },
  {
   "start": 1055.65,
   "end": 1056.93,
   "text": "能超越Switch的"
  },
  {
   "start": 1056.93,
   "end": 1058.73,
   "text": "只可能是Switch2"
  },
  {
   "start": 1058.73,
   "end": 1059.73,
   "text": "讓我們一起"
  },
  {
   "start": 1059.73,
   "end": 1061.41,
   "text": "靜候它的到來"
  },
  {
   "start": 1061.41,
   "end": 1061.89,
   "text": "最後"
  },
  {
   "start": 1061.89,
   "end": 1064.29,
   "text": "我在動態裡發起了一個有獎爭集活動"
  },
  {
   "start": 1064.29,
   "end": 1067.33,
   "text": "歡迎大家在評論區留下自己和Switch的故事"
  },
  {
   "start": 1067.33,
   "end": 1069.81,
   "text": "讓我們好好地跟他說一聲"
  },
  {
   "start": 1069.81,
   "end": 1070.49,
   "text": "再見"
  }
 ]
}