{
 "segments": [
  {
   "start": 0.02,
   "end": 1.26,
   "text": "就在今天"
  },
  {
   "start": 1.26,
   "end": 5.94,
   "text": "我国首个脑机接口医疗服务政府指导价正式发布"
  },
  {
   "start": 5.94,
   "end": 7.14,
   "text": "消息一出"
  },
  {
   "start": 7.14,
   "end": 10.9,
   "text": "全世界科技和医学两届都精调了下"
  },
  {
   "start": 10.9,
   "end": 12.1,
   "text": "曾几何时"
  },
  {
   "start": 12.1,
   "end": 15.14,
   "text": "脑机接口是科幻小说里的黑科技"
  },
  {
   "start": 15.14,
   "end": 17.54,
   "text": "是实验室里昂贵的奢侈品"
  },
  {
   "start": 17.54,
   "end": 21.02,
   "text": "美国更是用数十上百万美元的落地价格"
  },
  {
   "start": 21.02,
   "end": 23.42,
   "text": "劝退了所有的普通阶层"
  },
  {
   "start": 23.42,
   "end": 25.02,
   "text": "湖北省的定价政策"
  },
  {
   "start": 25.02,
   "end": 27.86,
   "text": "为它私下了只服务于权贵的标签"
  },
  {
   "start": 28.02,
   "end": 31.06,
   "text": "我国的脑机接口医疗服务不要百万"
  },
  {
   "start": 31.06,
   "end": 32.18,
   "text": "也不要十万"
  },
  {
   "start": 32.18,
   "end": 33.9,
   "text": "甚至不用上W"
  },
  {
   "start": 33.9,
   "end": 37.1,
   "text": "让脑机接口真正从科幻走进现实"
  },
  {
   "start": 37.1,
   "end": 39.14,
   "text": "从实验室走进临床"
  },
  {
   "start": 39.14,
   "end": 40.42,
   "text": "3月31日"
  },
  {
   "start": 40.42,
   "end": 43.98,
   "text": "世界脑机接口技术迎来了里程碑时刻"
  },
  {
   "start": 43.98,
   "end": 45.98,
   "text": "湖北省医保局正式发布"
  },
  {
   "start": 45.98,
   "end": 49.94,
   "text": "全国首个脑机接口医疗服务政府指导价"
  },
  {
   "start": 49.94,
   "end": 54.54,
   "text": "侵入市脑机接口置入费为6552元每次"
  },
  {
   "start": 54.58,
   "end": 59.1,
   "text": "侵入市脑机接口取出费为3139元每次"
  },
  {
   "start": 59.1,
   "end": 63.42,
   "text": "非侵入市脑机接口适配费为966元每次"
  },
  {
   "start": 63.42,
   "end": 65.54,
   "text": "政府现价 医保规范"
  },
  {
   "start": 65.54,
   "end": 67.58,
   "text": "不仅让技术安全可控"
  },
  {
   "start": 67.58,
   "end": 69.82,
   "text": "更让价格透明可及"
  },
  {
   "start": 69.82,
   "end": 70.66,
   "text": "这意味着"
  },
  {
   "start": 70.66,
   "end": 73.9,
   "text": "我国的脑机接口不再是权贵的特权"
  },
  {
   "start": 73.9,
   "end": 76.58,
   "text": "而是万千患者的救命稻草"
  },
  {
   "start": 76.58,
   "end": 77.86,
   "text": "这串数字背后"
  },
  {
   "start": 77.86,
   "end": 80.14,
   "text": "是无数普通家庭的贪患者"
  },
  {
   "start": 80.14,
   "end": 81.86,
   "text": "重获行走能力"
  },
  {
   "start": 81.86,
   "end": 84.3,
   "text": "失与者重新开口说话"
  },
  {
   "start": 84.34,
   "end": 86.74,
   "text": "盲人看见世界的希望之光"
  },
  {
   "start": 86.74,
   "end": 90.06,
   "text": "脑机接口终于从实验室的尖端科技"
  },
  {
   "start": 90.06,
   "end": 92.78,
   "text": "变成了触手可及的生命奇迹"
  },
  {
   "start": 92.78,
   "end": 96.3,
   "text": "脑机接口是如何改变患者命运的呢"
  },
  {
   "start": 96.3,
   "end": 99.94,
   "text": "人类大脑在思维活动时会产生脑电波"
  },
  {
   "start": 99.94,
   "end": 104.06,
   "text": "这些电波会被植入到大脑里面的传感器捕捉"
  },
  {
   "start": 104.06,
   "end": 106.86,
   "text": "并被芯片解码读取大脑意图"
  },
  {
   "start": 106.86,
   "end": 109.14,
   "text": "将其转化为计算机指令"
  },
  {
   "start": 109.14,
   "end": 111.22,
   "text": "从而实现人机交互"
  },
  {
   "start": 111.22,
   "end": 111.86,
   "text": "譬如"
  },
  {
   "start": 111.86,
   "end": 115.94,
   "text": "贪患患者通过脑机接口直接控制机械并"
  },
  {
   "start": 115.94,
   "end": 120.26,
   "text": "失与者通过脑机接口将思维转化为计算"
  },
  {
   "start": 120.26,
   "end": 123.3,
   "text": "脑机接口还能将眼前的实时图像"
  },
  {
   "start": 123.3,
   "end": 125.86,
   "text": "转换成电信号传输给大脑"
  },
  {
   "start": 125.86,
   "end": 128.62,
   "text": "从而让盲人重建光明"
  },
  {
   "start": 128.62,
   "end": 132.02,
   "text": "脑机接口给人类带来的远不止于此"
  },
  {
   "start": 132.02,
   "end": 135.38,
   "text": "理论上只要跟大脑和神经相关的疾病"
  },
  {
   "start": 135.38,
   "end": 138.66,
   "text": "都可以通过脑机接口技术得到康复"
  },
  {
   "start": 138.66,
   "end": 142.7,
   "text": "读帕金森、冰闲、抑郁症等精神类疾病"
  },
  {
   "start": 142.7,
   "end": 146.74,
   "text": "甚至可以赋予人类千里眼、顺风耳等超能力"
  },
  {
   "start": 146.74,
   "end": 148.9,
   "text": "深度开发人类的大脑"
  },
  {
   "start": 148.9,
   "end": 149.7,
   "text": "有人说"
  },
  {
   "start": 149.7,
   "end": 151.26,
   "text": "这次的破冰之举"
  },
  {
   "start": 151.26,
   "end": 154.26,
   "text": "中国把赛博朋克搬建了现实"
  },
  {
   "start": 154.26,
   "end": 156.06,
   "text": "但我认为更重要的是"
  },
  {
   "start": 156.06,
   "end": 158.7,
   "text": "这证明了科技是有温度的"
  },
  {
   "start": 158.7,
   "end": 161.62,
   "text": "当前沿技术被赋予普会的基因"
  },
  {
   "start": 161.62,
   "end": 164.06,
   "text": "就会激起人性与科技的共振"
  }
 ]
}