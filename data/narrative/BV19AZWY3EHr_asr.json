{
 "segments": [
  {
   "start": 0.0,
   "end": 2.2,
   "text": "各位必占的小伙伴们大家好"
  },
  {
   "start": 2.2,
   "end": 4.12,
   "text": "牧訊又和大家见面了"
  },
  {
   "start": 4.12,
   "end": 5.52,
   "text": "历经五年的时光"
  },
  {
   "start": 5.52,
   "end": 7.08,
   "text": "可能牧訊默默无闻"
  },
  {
   "start": 7.08,
   "end": 9.51,
   "text": "但从未停止免费的脚步"
  },
  {
   "start": 9.51,
   "end": 11.75,
   "text": "在此期间牧訊更新了很多"
  },
  {
   "start": 11.75,
   "end": 12.43,
   "text": "比如"
  },
  {
   "start": 12.43,
   "end": 13.15,
   "text": "育癌"
  },
  {
   "start": 13.15,
   "end": 13.95,
   "text": "节点"
  },
  {
   "start": 13.95,
   "end": 14.99,
   "text": "服务器等"
  },
  {
   "start": 14.99,
   "end": 17.59,
   "text": "同样也发生了很多事情和变过"
  },
  {
   "start": 17.59,
   "end": 20.35,
   "text": "接下来已经到底一边测试延迟"
  },
  {
   "start": 20.35,
   "end": 24.74,
   "text": "一边和大家说说关于牧訊的事情"
  },
  {
   "start": 24.74,
   "end": 27.7,
   "text": "关于某些小伙伴质疑牧訊是不是挖矿"
  },
  {
   "start": 27.7,
   "end": 29.54,
   "text": "说占用代宽和GPU"
  },
  {
   "start": 29.62,
   "end": 31.7,
   "text": "现在安装包优化到2MB"
  },
  {
   "start": 31.7,
   "end": 33.74,
   "text": "文件都是通过在线安装"
  },
  {
   "start": 33.74,
   "end": 35.82,
   "text": "欢迎各界技术大佬监督"
  },
  {
   "start": 35.82,
   "end": 38.94,
   "text": "如果牧訊加速器出现任何违规违法行为"
  },
  {
   "start": 38.94,
   "end": 40.5,
   "text": "请立即正义执行"
  },
  {
   "start": 40.5,
   "end": 44.5,
   "text": "牧訊免费到现在问心无愧"
  },
  {
   "start": 44.5,
   "end": 46.3,
   "text": "关于取消登录的原因"
  },
  {
   "start": 46.3,
   "end": 49.62,
   "text": "有些小伙伴觉得用邮箱注册会留下隐患"
  },
  {
   "start": 49.62,
   "end": 52.74,
   "text": "所以我们尊重每位牧訊用户的建议和意见"
  },
  {
   "start": 52.74,
   "end": 54.1,
   "text": "直接安装使用"
  },
  {
   "start": 54.1,
   "end": 61.9,
   "text": "无需注册和登录"
  },
  {
   "start": 61.9,
   "end": 66.7,
   "text": "整局游戏延迟一直稳定在50左右"
  },
  {
   "start": 66.74,
   "end": 72.76,
   "text": "接下来测试路阿路台服"
  },
  {
   "start": 72.76,
   "end": 75.28,
   "text": "一般玩路阿路台服的玩家都知道"
  },
  {
   "start": 75.28,
   "end": 77.32,
   "text": "只要可以登录到客户端界面"
  },
  {
   "start": 77.32,
   "end": 79.2,
   "text": "那么游戏就可以正常游玩"
  },
  {
   "start": 79.2,
   "end": 80.76,
   "text": "所以时间有限"
  },
  {
   "start": 80.76,
   "end": 83.48,
   "text": "而且这个账号等级低不能玩匹配"
  },
  {
   "start": 83.48,
   "end": 84.56,
   "text": "具体情况怎样"
  },
  {
   "start": 84.56,
   "end": 88.87,
   "text": "欢迎大家亲自测试"
  },
  {
   "start": 88.87,
   "end": 90.07,
   "text": "接下来已经到底"
  },
  {
   "start": 90.07,
   "end": 119.06,
   "text": "10倍加速测试PUBG"
  },
  {
   "start": 119.06,
   "end": 120.5,
   "text": "关于暴毒原因"
  },
  {
   "start": 120.5,
   "end": 121.86,
   "text": "一般安装程序"
  },
  {
   "start": 121.86,
   "end": 124.14,
   "text": "杀软会判断是否有签名"
  },
  {
   "start": 124.14,
   "end": 125.5,
   "text": "没有就会暴毒"
  },
  {
   "start": 125.5,
   "end": 126.78,
   "text": "牧訊组建以来"
  },
  {
   "start": 126.78,
   "end": 128.74,
   "text": "写程序日常维护更新"
  },
  {
   "start": 128.74,
   "end": 129.58,
   "text": "预名"
  },
  {
   "start": 129.58,
   "end": 131.66,
   "text": "成员管理都是加入牧訊以后"
  },
  {
   "start": 131.66,
   "end": 133.98,
   "text": "自告奋勇站出来帮忙的小伙伴们"
  },
  {
   "start": 133.98,
   "end": 135.94,
   "text": "可以说是真正的无常奉献"
  },
  {
   "start": 135.94,
   "end": 138.02,
   "text": "在这里也谢谢各位的付出"
  },
  {
   "start": 138.02,
   "end": 140.06,
   "text": "所以几千亿年的签名费用"
  },
  {
   "start": 140.06,
   "end": 142.14,
   "text": "真是差到了免费的解压股"
  },
  {
   "start": 142.14,
   "end": 217.08,
   "text": "一整局测试下来"
  },
  {
   "start": 217.08,
   "end": 218.8,
   "text": "稳定在20-30"
  },
  {
   "start": 218.8,
   "end": 224.94,
   "text": "非常低的延迟"
  },
  {
   "start": 224.94,
   "end": 227.5,
   "text": "接下来测试星际战甲更新速度"
  },
  {
   "start": 227.5,
   "end": 228.74,
   "text": "由于事情太多"
  },
  {
   "start": 228.74,
   "end": 230.18,
   "text": "就没有具体游玩"
  },
  {
   "start": 230.18,
   "end": 231.46,
   "text": "可以看到更新速度"
  },
  {
   "start": 231.46,
   "end": 233.26,
   "text": "平均在15MB每秒"
  },
  {
   "start": 233.26,
   "end": 235.54,
   "text": "峰值达到了每秒30MB左右"
  },
  {
   "start": 235.58,
   "end": 237.66,
   "text": "游玩的话也是没任何问题"
  },
  {
   "start": 237.66,
   "end": 238.82,
   "text": "具体延迟如何"
  },
  {
   "start": 238.82,
   "end": 240.86,
   "text": "还是小伙伴亲自测试知晓"
  }
 ]
}